# 🌍 SentinelOps Configuration - UNDP Emergency Response Platform

# 📦 PostgreSQL + PostGIS Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=sentinelops
DATABASE_URL=postgresql://postgres:postgres@db:5432/sentinelops

# 🔴 Redis Cache (Background tasks & sync)
REDIS_URL=redis://redis:6379/0

# 🔐 Security
SECRET_KEY=your-super-secure-key-change-in-production
ENV=development

# 📁 File Upload Configuration
UPLOAD_DIR=/app/uploads
MAX_UPLOAD_SIZE_MB=20

# 🎨 Frontend Configuration
VITE_API_URL=/api/v1
VITE_SESSION_SECRET=sentinelops-tactical-session-2026
VITE_HMR_HOST=localhost
VITE_HMR_PORT=5173
VITE_HMR_PROTOCOL=ws

# 📱 SMS Gateway (Optional - for fallback alerts)
SMS_GATEWAY_API_KEY=your-sms-api-key
SMS_GATEWAY_URL=https://api.gateway.com/send

# 🗺️ Map Configuration
MAP_TILE_PROVIDER=https://tile.openstreetmap.org
SENTINEL_API_KEY=your-sentinel-hub-key

# 🚀 Deployment Settings
LOG_LEVEL=info
CORS_ORIGINS=*
ALLOW_CREDENTIALS=true

# 🐳 Docker Network (DO NOT CHANGE)
BACKEND_URL=http://backend:8000
FRONTEND_URL=http://frontend:5173
